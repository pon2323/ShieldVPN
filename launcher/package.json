{
  "name": "shieldvpn-launcher",
  "version": "2.1.0",
  "description": "ShieldVPN launcher and updater",
  "main": "main.js",
  "author": "ShieldVPN",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.shieldvpn.launcher",
    "productName": "ShieldVPN Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "ShieldVPNLauncherSetup.exe",
      "publisherName": "ShieldVPN"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShieldVPN Launcher",
      "deleteAppDataOnUninstall": false
    }
  }
}